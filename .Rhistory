}
# For each non-reference class column, fill in ratios and CIs
for (j in other_cols) {
# Vector of non-reference class column indices
cl_num <- as.integer(sub("^C", "", j))
# Get ratio estimates and CIs
ci <- svy_ratio_ci_row(svydes = svydes, v = v, class_var = class_var,
cl_num = cl_num, ref_num = ref_num,
ci_level = ci_level)
# Prevalence for variable and class, obtained from vars_across_class output
val <- value_matrix[i, j]
# Add ratio and ratio CI to output for the cell
output_df_new[i, j] <- sprintf("%s (%s, %d%% CI: %s-%s)",
val, # prevalence
fmt_num(ci$est, digits),  # ratio
round(ci_level * 100), # CI level
fmt_num(ci$lb, digits), # CI LB
fmt_num(ci$ub, digits)) # CI UB
}
}
# Return new output table
return(output_df_new)
}
# Add in ratio estimates and their 95% CIs
# Uses output_df, cov_df, cl_cols, ref_col defined in previous sections
output_df_with_ci <- add_ratio_cis(
output_df = output_df,
cov_df    = cov_df,
svydes    = svy_design,
cl_cols   = cl_cols,
ref_col   = ref_col,
digits    = digits,
ci_level  = ci_level
)
View(output_df_with_ci)
output_df_with_ci_temp <- output_df_with_ci
# NOTE: "Martial_Status" should be "Marital Status"
output_df_with_ci$Variable <- gsub("Martial", "Marital", output_df$Variable)
#   class_var: Name of the class variable in svydes$variables. Default is "Class".
#   verbose: Boolean specifying if progress text should be printed. Default
#            (`TRUE`) prints out progress.
#
# Value: Dataframe named `output_df_new` that has the ratios and confidence
# intervals added.
#
# Usage: add_ratio_cis(output_df = output_df, cov_df = cov_df,
#                      svydes = svy_design, cl_cols = cl_cols, ref_col = "C1",
#                      digits = digits, ci_level  = 0.95)
add_ratio_cis <- function(output_df, cov_df, svydes,
cl_cols, ref_col = "C1",
cov_rows = 3:nrow(output_df),
digits = 1, ci_level = 0.95,
class_var = "Class",
verbose = TRUE) {
# Parse the prevalence estimate (leading numeric value) from an output_df cell
# Works for: "12.3 (0.456)" or "12.3 (0.456, 95% CI: ...)" or "12.3"
parse_cell_value <- function(x) {
x <- sub("\\s*\\(.*$", "", x)
x <- as.numeric(x)
}
# Fix number of decimals displayed for numbers
fmt_num <- function(x, d) formatC(round(x, d), format = "f", digits = d)
# Extract the prevalence for each class column displayed in the table
# (% for categorical, mean for continuous)
value_matrix <- as.data.frame(lapply(output_df[cl_cols], function(col) {
vapply(col, parse_cell_value, numeric(1))
}))
names(value_matrix) <- cl_cols
# Initialize updated outputed table
output_df_new <- output_df
# Index for reference column (usually 1)
ref_num <- as.integer(sub("^C", "", ref_col))
# Column names for non-reference class columns
other_cols <- setdiff(cl_cols, ref_col)
# Because factor-level rows often have Variable == "", carry forward the last
# non-empty Variable label
current_var_label <- NA_character_
for (i in cov_rows) {
# Update carried-forward variable label (for factor blocks with blank
# Variable row values)
if (nzchar(output_df$Variable[i])) {
current_var_label <- output_df$Variable[i]
}
# Must have a usable carried-forward variable label
if (is.na(current_var_label) || !nzchar(current_var_label)) {
stop(paste0("No variable name found for row ", i))
}
# Simplify displayed label (e.g., "Sex: %", "Age: Mean") back to cov_df
# column name and
clean_var <- gsub(": %$|: Mean$", "", current_var_label)
# Select the values of variable for all individuals, from cov_df
actual_var <- cov_df[[clean_var]]
# Build numeric row-variable v.
# If categorical cov, v is binary and is 1 if actual_var == this row's level,
# and 0 otherwise.
# If continuous cov, v = actual_var
if (is.factor(actual_var)) {
level_name <- output_df$Level[i]
v <- as.numeric(actual_var == level_name)
} else {
v <- as.numeric(actual_var)
}
# Print progress updates if desired
if (verbose) {
print(paste0("Calculating ratio and CI for variable ", current_var_label,
" level ", output_df$Level[i]))
}
# For each non-reference class column, fill in ratios and CIs
for (j in other_cols) {
# Vector of non-reference class column indices
cl_num <- as.integer(sub("^C", "", j))
# Get ratio estimates and CIs
ci <- svy_ratio_ci_row(svydes = svydes, v = v, class_var = class_var,
cl_num = cl_num, ref_num = ref_num,
ci_level = ci_level)
# Prevalence for variable and class, obtained from vars_across_class output
val <- value_matrix[i, j]
# Add ratio and ratio CI to output for the cell
output_df_new[i, j] <- sprintf("%s (%s [%s, %s]",
val, # prevalence
fmt_num(ci$est, digits),  # ratio
fmt_num(ci$lb, digits), # CI LB
fmt_num(ci$ub, digits)) # CI UB
}
}
# Return new output table
return(output_df_new)
}
# Add in ratio estimates and their 95% CIs
# Uses output_df, cov_df, cl_cols, ref_col defined in previous sections
output_df_with_ci <- add_ratio_cis(
output_df = output_df,
cov_df    = cov_df,
svydes    = svy_design,
cl_cols   = cl_cols,
ref_col   = ref_col,
digits    = digits,
ci_level  = ci_level
)
