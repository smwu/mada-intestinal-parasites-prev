# Reference category is set to largest categories: females, age [20,50)
mutate(sex = factor(sex, levels = c(1, 0), labels = c("F", "M")),
age_cat = factor(age_cat, levels = c("[20,50)", "[0,2)", "[2,5)",
"[5,12)", "[12,20)", "[50,Inf)")))
