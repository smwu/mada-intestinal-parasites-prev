# Function to tidy up the prevalences to display in a table
tidy_prev <- function(prev_summ) {
tidy_summ <- paste0(format(prev_summ$mean * 100, 1), " (",
format(prev_summ$lower * 100, 1), ", ",
format(prev_summ$upper * 100, 1), ")")
return(tidy_summ)
}
