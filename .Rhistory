region = c("NE", "CP", "SE", "WC", "SW"),
x = c(48.8 + 0.15, 46.2 + 0.15, 47.0 + 0.15, 44.9 - 1.1, 45.1 - 1.1),
y = c(-14.5 - 0.15, -19.0 - 0.15, -22.5 + 0.65, -20.8 - 0.15, -24.3 + 0.65)
)
